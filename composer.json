{
    "name": "clvarley/example-php",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "vimeo/psalm": "^6.16",
        "phpunit/phpunit": "^12.5",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "__YourNamespace__\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "__YourNamespace__\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "tests:unit": "@php vendor/bin/phpunit --testsuite=unit --no-coverage",
        "tests:feature": "@php vendor/bin/phpunit --testsuite=feature --no-coverage",
        "tests": ["@tests:unit", "@tests:feature"],
        "coverage": "@php -d xdebug.mode=coverage vendor/bin/phpunit --testsuite=unit",
        "style": "@php vendor/bin/php-cs-fixer fix --diff",
        "psalm": "@php vendor/bin/psalm --show-info=true"
    }
}
